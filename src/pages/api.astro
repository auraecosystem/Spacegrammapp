export const config = {
  runtime: "edge",
};

import type { APIRoute } from "astro";

interface User {
  id: number;
  name: string;
  email: string;
}

const users: User[] = [
  {
    id: 1,
    name: "seriki yakub",
    email: "webapp4@outlook.com",
  },
  {
    id: 2,
    name: "builder",
    email: "builder@openclaw.ai",
  },
  {
    id: 3,
    name: "kubu",
    email: "kubucoin@proton.me",
  },
  {
    id: 4,
    name: "spacegramm",
    email: "bot@outlook.com",
  },
  {
    id: 5,
    name: "web4",
    email: "mailman3@ietf.org",
  },
];

const jsonHeaders = {
  "Content-Type": "application/json",
};

function json(data: unknown, status = 200) {
  return new Response(JSON.stringify(data), {
    status,
    headers: jsonHeaders,
  });
}

export const GET: APIRoute = async ({ request }) => {
  try {
    const url = new URL(request.url);

    const idParam = url.searchParams.get("id");

    // Return all users
    if (!idParam) {
      return json({
        success: true,
        count: users.length,
        data: users,
      });
    }

    // Validate numeric ID
    const id = Number.parseInt(idParam, 10);

    if (Number.isNaN(id)) {
      return json(
        {
          success: false,
          error: "Invalid user id",
        },
        400
      );
    }

    const user = users.find((user) => user.id === id);

    if (!user) {
      return json(
        {
          success: false,
          error: "User not found",
        },
        404
      );
    }

    return json({
      success: true,
      data: user,
    });
  } catch (error) {
    return json(
      {
        success: false,
        error: "Internal server error",
      },
      500
    );
  }
};
